{
  "comment": "Typecheck the serverless functions (Node + ESM). Vercel builds these separately from the Vite frontend; this is just for local `npm run typecheck:api`.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "../src/**/*.ts"]
}
