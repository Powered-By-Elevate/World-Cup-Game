# World Cup Family Draft — environment
#
# Sharing is OPTIONAL. With no config the app persists to localStorage on a
# single device (great for trying it out). To let the whole family play together
# across devices, point it at a Supabase project:
#
#   1. Create a project at https://supabase.com
#   2. Run supabase/migrations/20260607000000_app_kv.sql in the SQL editor
#   3. Copy the values below from Project Settings → API
#   4. Restart `npm run dev`
#
# Then share the in-app invite link (it carries a ?league= code) so everyone
# lands in the same pool.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Commissioner accounts directory (emails + last login) ---
# Server-side ONLY — used by the /api/users serverless endpoint to read
# auth.users (which the anon key can't). NEVER expose this to the browser; set
# it only in your Vercel project's Environment Variables, not in client code.
# Without it, the roster falls back to "lite" emails captured on sign-in.
#   SUPABASE_URL is optional here — it falls back to VITE_SUPABASE_URL.
SUPABASE_SERVICE_ROLE_KEY=

# --- Draft-day notifications (/api/notify-draft) ---
# Server-side ONLY (Vercel env). When the commissioner runs the draft we fan out
# a Web Push banner to everyone who opted in, plus an email to every member with
# an address (no opt-in needed for email).
#
# Web Push needs a VAPID keypair (generate once with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
#
# Email reuses your existing Gmail SMTP sender (the same account/app-password
# already configured for Supabase auth emails). SUPABASE_ANON_KEY falls back to
# VITE_SUPABASE_ANON_KEY.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Live results (Zafronix WC API) ---
# Server-side ONLY — used by the /api/results serverless proxy, never exposed to
# the browser. Get a key at https://api.zafronix.com — sent as X-API-Key.
# Set this in your Vercel project's Environment Variables (not committed).
# Free tier: all fixtures + "live" flags + final scores (no in-play scores).
#   ZAFRONIX_YEAR defaults to "2026" if unset.
ZAFRONIX_API_KEY=
ZAFRONIX_YEAR=2026
